# FastAPI
ENVIRONMENT=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# LLM Configuration
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-3.5-turbo
LLM_API_KEY=
LLM_API_BASE_URL=https://openrouter.ai/api/v1
# Controls GET /llm-limits response shape.
# safe: returns only app-safe normalized fields:
#   provider, model, limit, limit_remaining, limit_reset,
#   usage, usage_daily, usage_weekly, usage_monthly,
#   byok_usage*, is_free_tier, rate_limit, expires_at, timestamp.
#   Removes provider-only metadata such as key label, creator_user_id,
#   management/provisioning flags, and any future raw provider fields.
# full: returns all safe fields plus provider_payload with the original
#   provider response. Use only for local debugging, not production UI/API.
LLM_LIMITS_RESPONSE_MODE=safe

# Database bootstrap admin connection
# These credentials point to the shared PostgreSQL infra project.
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Application database, schema, and users
DATABASE_URL=
PDLC_DB_NAME=
PDLC_DB_SCHEMA=
PDLC_DB_USER=
PDLC_DB_PASSWORD=
# Optional read-only user for analytics/support access.
PDLC_READONLY_USER=
PDLC_READONLY_PASSWORD=
DATABASE_ECHO=false

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Vector Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Observability
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true

# Security
ENABLE_GUARDRAILS=true
ENABLE_PROMPT_INJECTION_CHECK=true
ENABLE_SECRETS_CHECK=true
ENABLE_PII_MASKING=true

# Feature Flags
ENABLE_RAG=false
ENABLE_METRICS_DASHBOARD=false
ENABLE_HUMAN_APPROVAL=true

# UI
UI_HOST=0.0.0.0
UI_PORT=3000
